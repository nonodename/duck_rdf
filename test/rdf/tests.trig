@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@base <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix uni: <http://unicode.org/> .

_:read_rdf {
    <book/123> dc:creator <http://example.org/person/JohnDoe> ;
        dc:title "The Great Book" .

    uni:duck uni:hasEmoji "🦆" .

    _:jane a foaf:Person;
        foaf:name "Jane Smith"@en  .

    <person/JohnDoe> a foaf:Person ;
        foaf:age 30 ;
        foaf:knows _:jane ;
        foaf:name "John Doe" .
}