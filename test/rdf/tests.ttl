@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@base <http://example.org/> .
@prefix uni: <http://unicode.org/> .

<person/JohnDoe>
    a foaf:Person ;
    foaf:name "John Doe" ;
    foaf:age 30 ;
    foaf:knows _:jane .

_:jane
    a foaf:Person ;
    foaf:name "Jane Smith"@en .

<book/123>
    dc:title "The Great Book" ;
    dc:creator <person/JohnDoe> .

uni:duck
    uni:hasEmoji "🦆" .
