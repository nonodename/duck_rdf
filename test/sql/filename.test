# name: test/sql/filename.test
# description: test filename parameter in read_rdf extension
# group: [sql]

require rdf

# Default: 6 columns, no filename column
query I
SELECT COUNT(*) FROM read_rdf('test/rdf/shards/shard_a.nt');
----
3

# filename=false is a no-op — still 6 columns
query I
SELECT COUNT(*) FROM read_rdf('test/rdf/shards/shard_a.nt', filename = false);
----
3

# filename=true adds a 7th column with the source file path
# note use of replace to make tests work across windows and unix derived
query IT
SELECT COUNT(*), replace(filename,'\','/')
FROM read_rdf('test/rdf/shards/shard_a.nt', filename = true)
GROUP BY filename;
----
3	test/rdf/shards/shard_a.nt

# Glob: rows from both shards carry distinct filenames
query IT
SELECT COUNT(*), replace(filename,'\','/')
FROM read_rdf('test/rdf/shards/*.nt', filename = true)
GROUP BY filename
ORDER BY filename;
----
3	test/rdf/shards/shard_a.nt
2	test/rdf/shards/shard_b.nt

# Projection pushdown: select only filename column
query T
SELECT DISTINCT replace(filename,'\','/')
FROM read_rdf('test/rdf/shards/shard_a.nt', filename = true);
----
test/rdf/shards/shard_a.nt

# Projection pushdown: subject + filename, skipping all intermediate columns
query TT
SELECT subject, replace(filename,'\','/')
FROM read_rdf('test/rdf/shards/shard_a.nt', filename = true)
ORDER BY subject;
----
http://example.org/s1	test/rdf/shards/shard_a.nt
http://example.org/s2	test/rdf/shards/shard_a.nt
http://example.org/s3	test/rdf/shards/shard_a.nt

# COUNT(*) with filename=true: filename slot not projected, must not crash
query I
SELECT COUNT(*) FROM read_rdf('test/rdf/shards/*.nt', filename = true);
----
5

# LIST[VARCHAR]: filename column tracks the originating file per row
query IT
SELECT COUNT(*), replace(filename,'\','/')
FROM read_rdf(['test/rdf/shards/shard_a.nt', 'test/rdf/shards/shard_b.nt'], filename = true)
GROUP BY filename
ORDER BY filename;
----
3	test/rdf/shards/shard_a.nt
2	test/rdf/shards/shard_b.nt
