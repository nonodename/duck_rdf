# name: test/sql/write_rdf.test
# description: test write RDF support via COPY ... TO ... (FORMAT r2rml)
# group: [sql]

require rdf

# ── Setup ─────────────────────────────────────────────────────────────────────
# emp: unquoted identifiers — DuckDB folds to lowercase (empno, ename, deptno).
# emp_quoted: quoted identifiers — DuckDB preserves case (EMPNO, ENAME, DEPTNO).
statement ok
CREATE TABLE emp AS SELECT 7369 AS EMPNO, 'SMITH' AS ENAME, 10 AS DEPTNO;

statement ok
CREATE TABLE emp_quoted AS SELECT 7369 AS "EMPNO", 'SMITH' AS "ENAME", 10 AS "DEPTNO";

# ── Inside-out mode ───────────────────────────────────────────────────────────
# The mapping (test/r2rml/inside_out.ttl) has no rr:logicalTable.
# DuckDB drives the SELECT and passes rows to the extension via copy_to_sink.
# ignore_case true: DuckDB folds identifiers to lowercase; the extension
# lowercases the mapping's uppercase column refs to match.

statement ok
COPY (SELECT EMPNO, ENAME, DEPTNO FROM emp)
TO '__TEST_DIR__/io_out.nt'
(FORMAT r2rml, mapping 'test/r2rml/inside_out.ttl', ignore_case true);

# Read back the generated file and count triples (3 expected: rdf:type + name + department)
query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/io_out.nt');
----
3

# Verify the literal triple
query T
SELECT object FROM read_rdf('__TEST_DIR__/io_out.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#name';
----
SMITH

# Verify the template-based IRI triple
query T
SELECT object FROM read_rdf('__TEST_DIR__/io_out.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#department';
----
http://data.example.com/department/10

# Verify the rdf:type triple
query T
SELECT object FROM read_rdf('__TEST_DIR__/io_out.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://www.w3.org/1999/02/22-rdf-syntax-ns#type';
----
http://example.com/ns#Employee

# All three triples share the same subject
query T
SELECT DISTINCT subject FROM read_rdf('__TEST_DIR__/io_out.nt');
----
http://data.example.com/employee/7369

# ── Full R2RML mode ───────────────────────────────────────────────────────────
# The mapping (test/r2rml/full_r2rml_lower.ttl) has rr:logicalTable [ rr:tableName "emp" ].
# The extension ignores the COPY SELECT and queries the EMP table itself.
# In full R2RML mode column name matching goes through MapSQLRow (sql2rdf library)
# which does exact-case lookup, so the mapping must use lowercase refs to match
# DuckDB's lowercase-folded column names regardless of ignore_case.

statement ok
COPY (SELECT 1) TO '__TEST_DIR__/full_out.nt'
(FORMAT r2rml, mapping 'test/r2rml/full_r2rml_lower.ttl', ignore_case true);

# Same three triples expected, same subject
query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/full_out.nt');
----
3

query T
SELECT object FROM read_rdf('__TEST_DIR__/full_out.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#name';
----
SMITH

# ── rdf_format option ─────────────────────────────────────────────────────────
# Turtle output is valid; verify the file can be read back with read_rdf.

statement ok
COPY (SELECT EMPNO, ENAME, DEPTNO FROM emp)
TO '__TEST_DIR__/io_out.ttl'
(FORMAT r2rml, mapping 'test/r2rml/inside_out.ttl', rdf_format 'turtle', ignore_case true);

query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/io_out.ttl', file_type = 'ttl');
----
3

# NQuads format
statement ok
COPY (SELECT EMPNO, ENAME, DEPTNO FROM emp)
TO '__TEST_DIR__/io_out.nq'
(FORMAT r2rml, mapping 'test/r2rml/inside_out.ttl', rdf_format 'nquads', ignore_case true);

query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/io_out.nq');
----
3

# ── Error cases ───────────────────────────────────────────────────────────────

# mapping option is required
statement error
COPY (SELECT 1) TO '__TEST_DIR__/x.nt' (FORMAT r2rml);
----
r2rml format requires a 'mapping' option

# mapping file not found
statement error
COPY (SELECT 1) TO '__TEST_DIR__/x.nt' (FORMAT r2rml, mapping 'nonexistent.ttl');
----
R2RML mapping file not found

# invalid rdf_format value
statement error
COPY (SELECT EMPNO FROM emp) TO '__TEST_DIR__/x.nt'
(FORMAT r2rml, mapping 'test/r2rml/inside_out.ttl', rdf_format 'jsonld');
----
Unknown rdf_format

# mapping that is neither valid inside-out nor fully valid R2RML
statement error
COPY (SELECT 1) TO '__TEST_DIR__/x.nt'
(FORMAT r2rml, mapping 'sql2rdf/tests/sourceR2RML/inside_out_with_rom.ttl');
----
not valid

# ── ignore_non_fatal_errors option ────────────────────────────────────────────
# The flag is accepted and has no effect when the mapping has no parse errors.

statement ok
COPY (SELECT EMPNO, ENAME, DEPTNO FROM emp)
TO '__TEST_DIR__/io_nfe_explicit.nt'
(FORMAT r2rml, mapping 'test/r2rml/inside_out.ttl', ignore_non_fatal_errors true, ignore_case true);

query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/io_nfe_explicit.nt');
----
3

# With ignore_non_fatal_errors = false the parser throws on the first
# non-fatal error (here: unresolved parentTriplesMap), surfaced as an
# InvalidInput exception with "R2RML mapping parse error" prefix.
# Note: the same mapping with ignore_non_fatal_errors = true (the default)
# still fails at the isValid() check because the null parentTriplesMap renders
# the mapping invalid — so this test isolates the strict-parse path.
statement error
COPY (SELECT 1) TO '__TEST_DIR__/nfe_strict.nt'
(FORMAT r2rml, mapping 'sql2rdf/tests/sourceR2RML/valid_r2rml_unresolved_parent.ttl',
 ignore_non_fatal_errors false);
----
R2RML mapping parse error

# ── ignore_case true ──────────────────────────────────────────────────────────
# DuckDB folds unquoted identifiers to lowercase. ignore_case true lowercases
# both the column names from DuckDB and the lookup key from the mapping before
# matching. This allows a mapping with uppercase column refs (ENAME, {EMPNO})
# to match DuckDB's lowercase output in inside-out mode.
# Note: in full R2RML mode column lookup goes through MapSQLRow (sql2rdf library)
# which does exact-case comparison, so the mapping must always use lowercase refs
# matching DuckDB's output regardless of ignore_case.

# inside-out mode: uppercase mapping refs matched via case-folding
statement ok
COPY (SELECT empno, ename, deptno FROM emp)
TO '__TEST_DIR__/io_lower.nt'
(FORMAT r2rml, mapping 'test/r2rml/inside_out.ttl', ignore_case true);

query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/io_lower.nt');
----
3

query T
SELECT object FROM read_rdf('__TEST_DIR__/io_lower.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#name';
----
SMITH

query T
SELECT object FROM read_rdf('__TEST_DIR__/io_lower.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#department';
----
http://data.example.com/department/10

# full R2RML mode: mapping uses lowercase rr:tableName and column references
statement ok
COPY (SELECT 1) TO '__TEST_DIR__/full_lower.nt'
(FORMAT r2rml, mapping 'test/r2rml/full_r2rml_lower.ttl', ignore_case true);

query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/full_lower.nt');
----
3

query T
SELECT object FROM read_rdf('__TEST_DIR__/full_lower.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#name';
----
SMITH

# ── ignore_case false ─────────────────────────────────────────────────────────
# With ignore_case false (the default), column names are matched exactly as
# DuckDB returns them. The sql2rdf library uppercases column refs from the
# mapping before lookup, so this mode requires DuckDB to return uppercase column
# names — achieved by using quoted identifiers in the table definition.
# emp_quoted was created with "EMPNO", "ENAME", "DEPTNO" (quoted, case-preserved).

# inside-out mode: quoted uppercase columns match the mapping's uppercase refs exactly
statement ok
COPY (SELECT "EMPNO", "ENAME", "DEPTNO" FROM emp_quoted)
TO '__TEST_DIR__/io_exact.nt'
(FORMAT r2rml, mapping 'test/r2rml/inside_out.ttl', ignore_case false);

query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/io_exact.nt');
----
3

query T
SELECT object FROM read_rdf('__TEST_DIR__/io_exact.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#name';
----
SMITH

query T
SELECT object FROM read_rdf('__TEST_DIR__/io_exact.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#department';
----
http://data.example.com/department/10

# full R2RML mode: mapping references emp_quoted whose columns are uppercase
statement ok
COPY (SELECT 1) TO '__TEST_DIR__/full_exact.nt'
(FORMAT r2rml, mapping 'test/r2rml/full_r2rml_quoted.ttl', ignore_case false);

query I
SELECT COUNT(*) FROM read_rdf('__TEST_DIR__/full_exact.nt');
----
3

query T
SELECT object FROM read_rdf('__TEST_DIR__/full_exact.nt')
WHERE subject = 'http://data.example.com/employee/7369'
  AND predicate = 'http://example.com/ns#name';
----
SMITH

# ── XSD datatype output ───────────────────────────────────────────────────────
# Typed DuckDB columns should produce typed RDF literals carrying the correct
# XSD datatype URI in the object_datatype column when read back with read_rdf.

statement ok
CREATE TABLE typed_data AS SELECT
    1                                        AS id,
    42                                       AS int_col,
    true                                     AS bool_col,
    3.14::DOUBLE                             AS dbl_col,
    CAST(42.5 AS DECIMAL(5,1))               AS dec_col,
    CAST('2023-01-15' AS DATE)               AS date_col,
    CAST('09:30:00' AS TIME)                 AS time_col,
    CAST('2023-01-15 09:30:00' AS TIMESTAMP) AS ts_col,
    9999999999999::BIGINT                    AS bigint_col,
    'hello'                                  AS str_col;

statement ok
COPY (SELECT id, int_col, bool_col, dbl_col, dec_col, date_col, time_col, ts_col, bigint_col, str_col FROM typed_data)
TO '__TEST_DIR__/typed.nt'
(FORMAT r2rml, mapping 'test/r2rml/typed_cols.ttl', ignore_case true);

# INTEGER → xsd:int, value preserved
query TT
SELECT object, object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#intVal';
----
42	http://www.w3.org/2001/XMLSchema#int

# BOOLEAN → xsd:boolean, canonical form
query TT
SELECT object, object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#boolVal';
----
true	http://www.w3.org/2001/XMLSchema#boolean

# DOUBLE → xsd:double (just verify the datatype; exact string varies by platform)
query T
SELECT object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#dblVal';
----
http://www.w3.org/2001/XMLSchema#double

# DECIMAL → xsd:decimal
query TT
SELECT object, object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#decVal';
----
42.5	http://www.w3.org/2001/XMLSchema#decimal

# DATE → xsd:date in YYYY-MM-DD form
query TT
SELECT object, object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#dateVal';
----
2023-01-15	http://www.w3.org/2001/XMLSchema#date

# TIME → xsd:time
query T
SELECT object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#timeVal';
----
http://www.w3.org/2001/XMLSchema#time

# TIMESTAMP → xsd:dateTime with 'T' separator (not space)
query TT
SELECT object, object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#tsVal';
----
2023-01-15T09:30:00	http://www.w3.org/2001/XMLSchema#dateTime

# BIGINT → xsd:long
query TT
SELECT object, object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#bigintVal';
----
9999999999999	http://www.w3.org/2001/XMLSchema#long

# VARCHAR → plain string literal: no XSD datatype annotation (RDF 1.1 plain literal)
query T
SELECT object FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#strVal';
----
hello

query T
SELECT object_datatype FROM read_rdf('__TEST_DIR__/typed.nt')
WHERE predicate = 'http://example.com/types#strVal';
----
NULL
