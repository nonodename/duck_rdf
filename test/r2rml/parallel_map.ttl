@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix ex: <http://example.com/parallel#> .

# Inside-out mapping used to exercise PARALLEL_COPY_TO_FILE and the buffered
# sink's flush/threshold logic in src/r2rml_copy.cpp (see write_rdf_parallel.test).

<#RowMap>
    rr:subjectMap [
        rr:template "http://example.com/prow/{id}" ;
        rr:class ex:Row ;
    ] ;
    rr:predicateObjectMap [
        rr:predicate ex:val ;
        rr:objectMap [ rr:column "val" ] ;
    ] .
